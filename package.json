{
	"name": "graphforge",
	"version": "0.2.0",
	"description": "Immersive 3D knowledge graph visualization with physics engines, AI-powered suggestions, analytics, and time travel",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": ["obsidian", "graph", "visualization", "3d", "knowledge-graph", "three.js"],
	"author": "Bozo (644bo)",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^22.15.17",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"obsidian": "^1.8.7",
		"three": "^0.170.0",
		"typescript": "^5.7.0"
	}
}